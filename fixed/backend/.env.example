# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/journeybook

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Rate limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ────────────────────────────────────────────────────────
# FLIGHTS – Duffel API  (replaces Aviationstack)
# Sign up at https://app.duffel.com/join (free test account)
# Create a test token at: Dashboard → Developers → Access tokens
# Test tokens start with duffel_test_
DUFFEL_API_KEY=duffel_test_your_key_here

# ────────────────────────────────────────────────────────
# PAYMENTS – Stripe
# https://stripe.com — test keys start with sk_test_
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ────────────────────────────────────────────────────────
# AI – Anthropic  (for AI Travel Planner)
# https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here
